{
  "schemaType": "JSON",
  "schema": "{\"type\":\"object\", \"title\": \"TxnRecord\", \"properties\":{\"account_id\":{\"type\":\"string\"}, \"amount\":{\"type\":\"number\"} }, \"additionalProperties\": false}",
  "ruleSet": {
    "domainRules": [
      {
        "name": "trimWhitespaceAndHyphens",
        "kind": "TRANSFORM",
        "type": "CEL_FIELD",
        "mode": "WRITE",
        "expr": "name == 'account_id' ; value.replace(' ', '').replace('-', '')"
      },
      {
        "name": "checkIdLen",
        "kind": "CONDITION",
        "type": "CEL",
        "mode": "WRITE",
        "expr": "size(message.account_id) == 8",
        "onFailure": "DLQ",
        "params": {"dlq.topic": "dlq-topic"}
      }
    ]
  }
}
